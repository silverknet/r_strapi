# Copy to .env and fill in values. Never commit .env.

HOST=0.0.0.0
PORT=1337

APP_KEYS=key1,key2,key3,key4
JWT_SECRET=your-jwt-secret
ADMIN_JWT_SECRET=your-admin-jwt-secret
API_TOKEN_SALT=your-api-token-salt
TRANSFER_TOKEN_SALT=your-transfer-token-salt

# Local Docker Postgres (matches docker-compose.yml)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=strapi
PGUSER=strapi
PGPASSWORD=password

# Optional. If unset: SSL is off in development, on in production (see config/database.js).
# DATABASE_SSL=false

CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

FACEBOOK_API_TOKEN=
FACEBOOK_PAGE_ID=

# Optional — for npm run db:dump-from-prod / db:sync-from-prod (never commit; use .env.production.local)
# PRODUCTION_DATABASE_URL=postgresql://user:pass@host:port/dbname
