{
  "name": "strapi",
  "private": true,
  "version": "0.1.0",
  "description": "A Strapi application",
  "scripts": {
    "develop": "strapi develop",
    "develop:clean": "rm -rf .cache && strapi develop",
    "start": "strapi start",
    "build": "strapi build",
    "forcenews": "node scripts/force-news.js",
    "strapi": "strapi",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:dump-from-prod": "bash scripts/dump-from-prod.sh",
    "db:load-dump": "bash scripts/load-dump.sh",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:sync-from-prod": "bash scripts/sync-from-prod.sh",
    "test:facebook": "curl -sS http://127.0.0.1:1337/api/update-news/test-latest-facebook"
  },
  "dependencies": {
    "@retikolo/drag-drop-content-types": "2.0.0",
    "@strapi/plugin-users-permissions": "5.40.0",
    "@strapi/provider-upload-cloudinary": "5.40.0",
    "@strapi/strapi": "5.40.0",
    "pg": "8.8.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "author": {
    "name": "A Strapi developer"
  },
